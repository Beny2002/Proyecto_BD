
CREATE TABLE IF NOT EXISTS reproducciones (
    id_reproduccion INT NOT NULL AUTO_INCREMENT,
    id_usuario      INT NOT NULL,
    id_cancion      INT NOT NULL,
    fecha_hora      DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT pk_reproduccion PRIMARY KEY (id_reproduccion),
    CONSTRAINT fk_repro_usuario FOREIGN KEY (id_usuario)
        REFERENCES usuarios(id_usuario)
        ON DELETE CASCADE
        ON UPDATE CASCADE,
    CONSTRAINT fk_repro_cancion FOREIGN KEY (id_cancion)
        REFERENCES canciones(id_cancion)
        ON DELETE RESTRICT
        ON UPDATE CASCADE
);
